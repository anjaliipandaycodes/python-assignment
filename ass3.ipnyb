#read........

try:
    file = open("numbers.txt", "r")

    numbers = file.readlines()

    total = 0

    for i in numbers:
        total = total + int(i)

    average = total / len(numbers)

    print("Total:", total)
    print("Average:", average)

    file.close()

except FileNotFoundError:
    print("File does not exist")